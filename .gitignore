# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

*.pyo
*.pyd

.env

# Virtual environment
.venv/

# Jupyter
.ipynb_checkpoints/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage
.coverage
htmlcov/

# Editors / OS
.vscode/
.idea/
.DS_Store

# Data
data/raw/*
data/interim/*
data/processed/*

# Keep folder structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Allow DVC metafiles
!data/raw/*.dvc
!data/interim/*.dvc
!data/processed/*.dvc


data/**
!data/**/*.dvc
