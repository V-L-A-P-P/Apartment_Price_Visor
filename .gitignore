# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

*.pyo
*.pyd

.env

# Virtual environment
.venv/

# Jupyter
.ipynb_checkpoints/

# Tool caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Coverage
.coverage
htmlcov/

# Editors / OS
.vscode/
.idea/
.DS_Store

# Data - ignore actual data files but keep structure and DVC metafiles
data/raw/*.parquet
data/raw/*.csv
data/raw/*.json
data/raw/*.jsonl
data/interim/*.parquet
data/interim/*.csv
data/processed/*.parquet
data/processed/*.csv

# Keep folder structure
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# Allow DVC metafiles (must be after the ignore rules)
!data/raw/*.dvc
!data/interim/*.dvc
!data/processed/*.dvc

# Also allow DVC files in subdirectories
!data/**/*.dvc

# DVC
.dvc/cache
.dvc/tmp
.dvc/updater
.dvc/state
.dvc/lock
.dvc/config
.dvc/config
